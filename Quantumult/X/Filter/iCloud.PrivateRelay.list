# > iCloud Private Relay
# https://developer.apple.com/cn/support/prepare-your-network-for-icloud-private-relay/
# https://mask-api.icloud.com/egress-ip-ranges.csv
# Allow for network traffic audits
host, mask.icloud.com, iCloud.PrivateRelay
host, mask.apple-dns.net, iCloud.PrivateRelay
host, mask-canary.icloud.com, iCloud.PrivateRelay
host, canary.mask.apple-dns.net, iCloud.PrivateRelay
host, mask-h2.icloud.com, iCloud.PrivateRelay
host, mask-t.apple-dns.net, iCloud.PrivateRelay
