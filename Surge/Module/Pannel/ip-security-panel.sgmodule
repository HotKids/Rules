#!name=IP Security Monitor
#!desc=显示 IP 风险评分、类型、DNS 泄露检测、代理策略和本地/入口/出口 IP 地理信息，支持网络变化自动通知
#!author=HotKids&ChatGPT&Claude
#!category=HotKids
#!system=ios
#!arguments=ipqs_key:null,risk_api:null,local_geoapi:bilibili,remote_geoapi:ipinfo,maxmind_key:null,mask_ip:0,tw_flag:cn,event_delay:2,notify:true,panel_interval:600
#!arguments-desc=【数据源】\n\n· [risk_api]: 风险评分\n可选值：ipqs / proxycheck / ippure / scamalytics\n不填写：四级回落 IPQS → ProxyCheck → IPPure → Scamalytics\n\n· [local_geoapi]: 本地 IP 地理\nbilibili = bilibili（中文，默认）\nbaidu = 百度 opendata（中文，省市区粒度）\nipsb = ip.sb（英文）\n\n· [remote_geoapi]: 入口/出口地区（仅影响地区，运营商始终用 ipinfo.io）\nipinfo = ipinfo.io（英文，默认）\nipapi / ipapi-zh = ip-api.com（英文 / 中文，免费版 http 明文）\nmaxmind / maxmind-zh = GeoLite2（英文 / 中文优先，需 maxmind_key）\n\n【凭据（可选）】\n\n· [ipqs_key]: IPQualityScore API Key\n仅 risk_api=ipqs 或回落模式需要\n\n· [maxmind_key]: MaxMind GeoLite 凭据\n格式：account_id:license_key（免费注册，1000 次/天）\n仅 remote_geoapi=maxmind / maxmind-zh 需要\n\n【显示】\n\n· [mask_ip]: IP 打码\n0 = 关闭（默认），1 = 部分打码（123.*.*.89），2 = 全部隐藏\n\n· [tw_flag]: 台湾地区旗帜\ncn = 🇨🇳（默认），tw = 🇹🇼\n\n【行为】\n\n· [event_delay]: 网络变化后延迟检测（秒），默认 2\n\n· [notify]: 网络变化时推送通知\ntrue = 推送（默认），false = 不推送\n\n· [panel_interval]: 面板刷新间隔（秒），默认 600\n需与 [Panel] update-interval 保持一致，供打码点击切换判定使用

[Panel]
ip-security-panel = script-name=ip-security-panel,update-interval=600

[Script]
# 面板手动触发
ip-security-panel = type=generic,timeout=15,script-path=https://raw.githubusercontent.com/HotKids/Rules/master/Surge/Module/Scripts/ip-security.js,argument=ipqs_key={{{ipqs_key}}}&risk_api={{{risk_api}}}&local_geoapi={{{local_geoapi}}}&remote_geoapi={{{remote_geoapi}}}&maxmind_key={{{maxmind_key}}}&mask_ip={{{mask_ip}}}&tw_flag={{{tw_flag}}}&panel_interval={{{panel_interval}}}

# 网络变化自动触发
ip-security-event = type=event,event-name=network-changed,timeout=15,script-path=https://raw.githubusercontent.com/HotKids/Rules/master/Surge/Module/Scripts/ip-security.js,argument=TYPE=EVENT&ipqs_key={{{ipqs_key}}}&risk_api={{{risk_api}}}&local_geoapi={{{local_geoapi}}}&remote_geoapi={{{remote_geoapi}}}&maxmind_key={{{maxmind_key}}}&mask_ip={{{mask_ip}}}&tw_flag={{{tw_flag}}}&event_delay={{{event_delay}}}&notify={{{notify}}}
