#!name=Komari Traffic Monitor
#!desc=基于 Komari 面板 API 聚合显示各节点累计流量、用量配额和到期信息
#!author=HotKids & Claude
#!category=HotKids
#!system=ios
#!arguments=url:null,token:null,nodes:null,traffic:true,usage:true,expire:true,sys:false,uptime:false,ping:false,price:false,region:false,cycle:false,title:📊 Komari 流量统计
#!arguments-desc=【参数说明】\n\n· [url]: Komari 面板地址（必填）\n格式：https://mon.example.com（无协议前缀时默认 https）\n\n· [token]: 后台 API Key（可选）\n私有站点或需显示隐藏节点时填写，以 Authorization: Bearer 发送\n\n· [nodes]: 节点筛选（可选）\n不填写：显示全部节点，按 Komari 权重排序\n写法1：nodes=HK-1;JP-1（精确名称，顺序即显示顺序）\n写法2：nodes=^HK;^JP（每个条目都是正则，匹配的都显示，条目内按权重）\n写法3：nodes=!测试|备用（"!"开头整体为一个正则，匹配的不显示）\n说明：名称和正则可混用；含 & 等特殊字符需先 URL encode\n\n【显示项开关】各自独立，true=显示 / false=隐藏\n· [traffic]: 累计 ↓↑ 两向流量（默认 true）\n· [usage]: 用量对比配额（默认 true；设有 traffic_limit 时，口径与 Komari 面板一致）\n· [expire]: 到期日 + 剩余天数（默认 true）\n· [sys]: CPU / 内存 / 磁盘 使用率（默认 false）\n· [uptime]: 在线时长（默认 false）\n· [ping]: 各 ping 任务近 1 小时延迟，每行两项，丢包时标注（默认 false）\n· [price]: 价格 / 计费周期（默认 false）\n· [region]: 名称前加地区（默认 false；ISO 两字母代码自动转国旗，其余原样显示）\n行序固定：累计 → 用量 → 系统 → 在线 → 延迟 → 价格 → 到期\n\n· [cycle]: 周期用量口径（默认 false）\n开启后用量行改为本计费周期精确用量（跨重启累计，行首标注「周期」）\n周期起点：expired_at 的每月对应日，无到期日按每月 1 号\n代价：每节点多一次历史查询；查询失败自动回退累计口径\n\n· [title]: 面板标题\n不填写时默认显示：📊 Komari 流量统计\n\n【显示规则】\n配额、到期日、价格、用量口径均读取 Komari 后台设置，无需逐台配置\n用量标签：⇅双向和 / ↑上行 / ↓下行 / max·min 取两向较大·较小值\nsys / uptime / ping 为瞬时数据仅在线节点显示；累计、用量、到期、价格离线也显示

[Panel]
komari-traffic-panel = script-name=komari-traffic,update-interval=300

[Script]
komari-traffic = type=generic,timeout=30,script-path=https://raw.githubusercontent.com/HotKids/Rules/master/Surge/Module/Scripts/komari-traffic.js,argument="url={{{url}}}&token={{{token}}}&nodes={{{nodes}}}&traffic={{{traffic}}}&usage={{{usage}}}&expire={{{expire}}}&sys={{{sys}}}&uptime={{{uptime}}}&ping={{{ping}}}&price={{{price}}}&region={{{region}}}&cycle={{{cycle}}}&title={{{title}}}"
