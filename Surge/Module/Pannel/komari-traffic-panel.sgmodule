#!name=Komari Traffic Monitor
#!desc=基于 Komari 面板 API 聚合显示各节点累计流量、用量配额和到期信息
#!author=HotKids & Claude
#!category=HotKids
#!system=ios
#!arguments=url:null,token:null,nodes:null,overview:true,traffic:true,usage:true,expire:true,ip:false,sys:false,uptime:false,ping:false,price:false,region:false,panel_interval:300,title:📊 Komari 流量统计
#!arguments-desc=【参数说明】\n\n· [url]: Komari 面板地址（必填）\n格式：https://mon.example.com（无协议前缀时默认 https）\n\n· [token]: 后台 API Key（可选）\n私有站点或需显示隐藏节点时填写，以 Authorization: Bearer 发送\n申请路径：Komari 管理后台 → 设置 → 登录 → 底部 API 密钥（可一键生成，最少 12 位）\n注意：该密钥为管理员级权限，务必确保面板地址为 https\n\n· [nodes]: 节点筛选（可选）\n不填写：显示全部节点，按 Komari 权重排序\n写法1：nodes=HK-1;JP-1（精确名称，顺序即显示顺序）\n写法2：nodes=^HK;^JP（每个条目都是正则，匹配的都显示，条目内按权重）\n写法3：nodes=!测试|备用（"!"开头整体为一个正则，匹配的不显示）\n说明：名称和正则可混用；含 & 等特殊字符需先 URL encode\n\n【显示项开关】各自独立，true=显示 / false=隐藏\n· [overview]: 顶部概览——在线数 / 点亮地区 / 全站流量总和（默认 true；统计全部节点，不受 nodes 筛选影响）\n· [traffic]: 流量 ↑↓（默认 true）\n· [usage]: 用量对比配额，三态（默认 true）\n  true = 累计口径（自开机累计，与 Komari 面板一致；未设配额的节点不显示此行）\n  cycle = 本计费周期精确用量（跨重启，行首标注「周期」；周期起点为 expired_at 的每月对应日，无到期日按每月 1 号；每节点多一次历史查询，失败自动回退累计口径）\n  false = 隐藏\n  配额与口径在 Komari 后台设置：节点编辑 → 流量阈值（阈值如 1000GB；统计方式对应 max/sum/min/仅上行/仅下行）\n· [expire]: 到期日 + 剩余天数（默认 true）\n· [ip]: 节点 IP（默认 false）\n  完整 IP 需配置 token；未配 token 时视 Komari 后台「向访客发送 IP 地址」开关显示打码形式或不显示\n  显示时默认打码（203.***.***.7），点击面板刷新在明文/打码间切换，自动刷新不切换\n· [sys]: CPU / 内存 / 磁盘 使用率（默认 false）\n· [uptime]: 在线时长，与价格同行（默认 false）\n· [ping]: 各 ping 任务近 1 小时延迟，一行一项，丢包时标注（默认 false）\n· [price]: 价格 / 计费周期（默认 false）\n· [region]: 名称前加地区（默认 false；ISO 两字母代码自动转国旗，其余原样显示）\n行序固定：IP → 流量 → 用量 → 系统 → 价格·在线 → 到期 → 延迟\n\n· [panel_interval]: 面板刷新间隔（秒），默认 300\n需与 [Panel] update-interval 保持一致，供 IP 打码点击切换判定使用\n\n· [title]: 面板标题\n不填写时默认显示：📊 Komari 流量统计\n\n【显示规则】\n配额、到期日、价格、用量口径均读取 Komari 后台设置，无需逐台配置\n用量标签：⇅双向和 / ↑上行 / ↓下行 / max·min 取两向较大·较小值\nsys / uptime / ping 为瞬时数据仅在线节点显示；累计、用量、到期、价格离线也显示

[Panel]
komari-traffic-panel = script-name=komari-traffic,update-interval=300

[Script]
komari-traffic = type=generic,timeout=30,script-path=https://raw.githubusercontent.com/HotKids/Rules/master/Surge/Module/Scripts/komari-traffic.js,argument="url={{{url}}}&token={{{token}}}&nodes={{{nodes}}}&overview={{{overview}}}&traffic={{{traffic}}}&usage={{{usage}}}&expire={{{expire}}}&ip={{{ip}}}&sys={{{sys}}}&uptime={{{uptime}}}&ping={{{ping}}}&price={{{price}}}&region={{{region}}}&panel_interval={{{panel_interval}}}&title={{{title}}}"
