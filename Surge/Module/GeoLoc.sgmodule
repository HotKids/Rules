#!name=SNS GeoLoc
#!desc=修改中国大陆常见社群 IP 归属地显示
#!system=ios
#!arguments=Proxy:SNS
### fork from https://raw.githubusercontent.com/ConnersHua/RuleGo/master/Surge/Module/GeoLoc.sgmodule

[Rule]
# bilibili
URL-REGEX,https:\/\/api\.bilibili\.com\/x\/v\d\/reply\/add,{{{Proxy}}}

# ByteDance
# (Amemv)
AND,((DOMAIN-KEYWORD,amemv.com,extended-matching),(PROTOCOL,UDP)),REJECT
DOMAIN-KEYWORD,-core-hl.amemv.com,{{{Proxy}}},extended-matching
DOMAIN-KEYWORD,-core-lf.amemv.com,{{{Proxy}}},extended-matching

# (TouTiao)
DOMAIN,ib.snssdk.com,{{{Proxy}}}

# Kuwo
DOMAIN,ip.i.kuwo.cn,{{{Proxy}}}

# Xiaohongshu
DOMAIN,edith.xiaohongshu.com,{{{Proxy}}},extended-matching

# Weibo
URL-REGEX,https:\/\/api\.weibo\.cn\/\d\/comments\/(create|reply),{{{Proxy}}}
URL-REGEX,https:\/\/weibo\.com\/ajax\/comments\/create,{{{Proxy}}}
URL-REGEX,https:\/\/api\.weibo\.cn\/\d\/statuses\/send,{{{Proxy}}}
# (Web)
DOMAIN,www.weibo.com,{{{Proxy}}}
DOMAIN,s.weibo.com,{{{Proxy}}}

# Zhihu
URL-REGEX,https:\/\/api\.zhihu\.com\/answers,{{{Proxy}}}
URL-REGEX,https:\/\/api\.zhihu\.com\/comment_v\d\/answers\/\d+\/comment,{{{Proxy}}}

[MITM]
hostname = %APPEND% api.bilibili.com, api.weibo.cn, weibo.com, api.zhihu.com
