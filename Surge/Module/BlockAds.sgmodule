http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/v2\/zzlogic\/mycontinenthomepage\? 'delpaths([["respData","topOpera","leftOpera"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/v2\/zzlogic\/mycontinenthomepage\? 'delpaths([["respData","topOpera","rightOpera2"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/v2\/zzlogic\/mycontinenthomepage\? 'delpaths([["respData","topActBanner"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/v2\/zzlogic\/mycontinenthomepage\? 'delpaths([["respData","bmArea"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zzx\/transfer\/getConfigInfo\? 'delpaths([["respData","freeMarketTabLeadPop"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zzx\/transfer\/getConfigInfo\? 'delpaths([["respData","topOperations"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/v2\/zzinfoshow\/getfeedflowinfo\? 'if .respData.userRed.campName == "OCD挂件" then del(.respData.userRed) else . end | .respData.infoData |= map(del(.rotateResource,.appRecommendResource,."cargoGroupCardV2"))'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/transfer\/getmymoretools$ 'walk(if type == "object" and .name == "免流量特权" then empty else . end) | del(.respData.groupList[] | select(.groupName == "活动参与" or .groupName == "金融工具"))'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/transfer\/getmyprofilev3$ 'delpaths([["respData","bmNewInfo"]])'
http-response-jq ^https:\/\/app\.{{{转转}}}\.com\/zz\/transfer\/getmyprofilev3$ 'del(.respData.itemGroupList[].itemList[] | select(.name == "天天赚钱" or .name == "借钱")) | del(.respData.itemGroupList[] | select(.groupType == 15))'

